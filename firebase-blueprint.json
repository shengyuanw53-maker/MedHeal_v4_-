{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information for patients and doctors",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "username": { "type": "string", "description": "Login username" },
        "role": { "type": "string", "enum": ["patient", "doctor"], "description": "User role" },
        "name": { "type": "string", "description": "Real name" },
        "age": { "type": "number", "description": "Age (for patients)" },
        "gender": { "type": "string", "enum": ["male", "female", "other"], "description": "Gender" },
        "createdAt": { "type": "number", "description": "Timestamp of account creation" }
      },
      "required": ["uid", "username", "role", "name"]
    },
    "Credential": {
      "title": "Credential",
      "description": "Mapping of username to uid and password (simplified for demo)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "password": { "type": "string" }
      },
      "required": ["uid", "password"]
    },
    "RecoveryLog": {
      "title": "RecoveryLog",
      "description": "A single daily log submission for recovery monitoring",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "timestamp": { "type": "number" },
        "phase": { "type": "string", "enum": ["early", "recovery"] },
        "symptoms": { "type": "array", "items": { "type": "string" } },
        "diet": { "type": "string" },
        "activity": { "type": "string" },
        "score": { "type": "number" },
        "isCompliant": { "type": "boolean" },
        "pointsEarned": { "type": "number" }
      },
      "required": ["id", "patientId", "timestamp", "phase", "symptoms"]
    },
    "ChatRoom": {
      "title": "ChatRoom",
      "description": "A metadata document for a conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorName": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageTime": { "type": "number" },
        "unreadCount": { "type": "object" }
      },
      "required": ["id", "patientId", "doctorId"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message sent by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" },
        "type": { "type": "string", "enum": ["text", "image", "system"] }
      },
      "required": ["id", "senderId", "content", "timestamp"]
    }
  },
  "firestore": {
    "users/{uid}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    },
    "credentials/{username}": {
      "schema": "Credential",
      "description": "Collection of login credentials"
    },
    "recovery_logs/{logId}": {
      "schema": "RecoveryLog",
      "description": "Daily postoperative recovery logs submitted by patients"
    },
    "chat_rooms/{roomId}": {
      "schema": "ChatRoom",
      "description": "Active communication channels between patients and doctors"
    },
    "chat_rooms/{roomId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Individual messages within a chat room"
    }
  }
}
